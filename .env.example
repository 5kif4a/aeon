# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
BOT_USERNAME=YOUR_BOT_USERNAME
# polling for local development, webhook for production (requires public WEBAPP_URL)
BOT_MODE=polling
WEBHOOK_SECRET=
# Public HTTPS URL of the Mini App (Vercel domain; ngrok URL for local Telegram testing)
WEBAPP_URL=
# Public HTTPS URL of the backend (Railway domain), used for the Telegram webhook
PUBLIC_URL=

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=2500

# Storage (these values match docker-compose services)
DATABASE_URL=postgresql+asyncpg://aeon:aeon@postgres:5432/aeon
REDIS_URL=redis://redis:6379/0
REDIS_AGENT_HISTORY_TTL=2592000

# Goal reminders
REMINDER_HOUR=9
REMINDER_TZ=UTC
